    {
      "parameters": {
        "splitInBatchesNotice": "",
        "batchSize": 1,
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1744,
        112
      ],
      "id": "split-batches",
      "name": "Split in Batches"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Convert the background image (binary 'data') to base64 for Cloud Run\n// This runs for each item in batch\n\nconst binaryProperty = 'data'; // Default binary property from Drive\nif (!items[0].binary || !items[0].binary[binaryProperty]) {\n  throw new Error(\"No binary data found for background image\");\n}\n\nconst buffer = await this.helpers.getBinaryDataBuffer(0, binaryProperty);\nconst base64Bg = buffer.toString('base64');\n\nreturn [{\n  json: {\n    ...items[0].json,\n    bg_image_base64: base64Bg\n  }\n}];",
        "notice": ""
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1968,
        112
      ],
      "id": "bg-to-base64",
      "name": "BG to Base64"
    },
    {
      "parameters": {
        "preBuiltAgentsCalloutHttpRequest": "",
        "curlImport": "",
        "method": "POST",
        "url": "={{ $('Set Variables').first().json.CLOUD_RUN_BASE }}/compose",
        "authentication": "none",
        "provideSslCertificates": false,
        "sendQuery": false,
        "sendHeaders": false,
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            {
              "name": "product_png_base64",
              "value": "={{ $json.product_png_base64 }}"
            },
            {
              "name": "bg_image_base64",
              "value": "={{ $json.bg_image_base64 }}"
            },
            {
              "name": "scale",
              "value": 0.78
            },
            {
              "name": "x",
              "value": 0.5
            },
            {
              "name": "y",
              "value": 0.58
            },
            {
              "name": "shadow",
              "value": true
            }
          ]
        },
        "options": {
          "responseFormat": "file"
        },
        "infoMessage": ""
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2192,
        112
      ],
      "id": "compose-scene",
      "name": "Compose Scene"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Collect all scenes from ALL executions of the loop\n// We access the data from the 'Compose Scene' node across all its executions\n\nconst allExecutions = $('Compose Scene').all();\nconst scenes = [];\n\nfor (const execution of allExecutions) {\n  // Each execution has one item (since we split batch size 1)\n  // But we need to use getBinaryDataBuffer which might tricky in 'all()'.\n  // Actually, standard Pattern is to use the output of the Loop directly if we Merge back.\n  // But for simple aggregation code node is easier if we can access binary.\n  \n  // Easier approach: Just return the binary index matching.\n  // However, .all() returns JSON+Binary references.\n  \n  // To get binary content of previous runs in a Code node safely, we often need to rely on the fact \n  // that they are available in memory OR use a Loop mechanism that Aggregates.\n  \n  if (execution.binary && execution.binary.data) {\n     // This call gets buffer for *current* item context usually.\n     // Accessing arbitrary binary from previous nodes in loop via .all() is restricted in some versions.\n     // Assuming version 1+ allows accessing binary items from 'all()'.\n     // We will try standard access.\n     // Note: In older n8n code node, accessing binary of other items is hard.\n     // Fallback: This node assumes it runs AFTER the loop is Done? code node runs once?\n     // No, we need to loop back.\n  }\n}\n// Let's assume we re-assemble after loop.\nreturn [];",
        "notice": ""
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
        -144
      ],
      "id": "collect-scenes-placeholder",
      "name": "Collect Scenes (Use Loop Merge Instead)",
      "disabled": true
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "",
        "notice": ""
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
        112
      ],
      "id": "aggregate-code",
      "name": "Aggregate Scenes",
      "jsCode": "// Runs once after loop finishes (connected to loop exit)\n// Wait, typically we connect output of SplitInBatches 'Done' to here.\n// But we need the data.\n\nconst composedItems = $('Compose Scene').all();\nconst scenes = [];\n\nfor (let i = 0; i < composedItems.length; i++) {\n    // We MUST use the helper with the item index and node name to get binary\n    // This works if the validation allows it.\n    const buffer = await this.helpers.getBinaryDataBuffer(i, 'data', 'Compose Scene');\n    scenes.push(buffer.toString('base64'));\n}\n\n// Get Plan Info\nconst plan = $('Parse Gemini JSON').first().json;\n\nreturn [{\n    json: {\n        scenes_base64: scenes,\n        durations: plan.durations,\n        overlay_text: plan.overlay_text,\n        fps: 30,\n        size: \"1080x1920\"\n    }\n}];"
    },
    {
      "parameters": {
        "preBuiltAgentsCalloutHttpRequest": "",
        "curlImport": "",
        "method": "POST",
        "url": "={{ $('Set Variables').first().json.CLOUD_RUN_BASE }}/render-video",
        "authentication": "none",
        "provideSslCertificates": false,
        "sendQuery": false,
        "sendHeaders": false,
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
