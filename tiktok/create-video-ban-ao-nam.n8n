    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $('Set Variables').first().json.GEMINI_API_KEY }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\":[{\n      \"text\": \"Bạn là chuyên gia dựng video quảng cáo thời trang TikTok. Sản phẩm: {{ $node[\\\"Read Pending Tasks\\\"].json.product_name }}. Bối cảnh: Trung tâm thương mại sang trọng hoặc Shop thời trang modern. Hãy trả về đúng định dạng JSON (không markdown) với cấu trúc sau cho video 15s (4 scenes): { \\\"background_prompts\\\": [\\\"mô tả cảnh 1\\\", \\\"mô tả cảnh 2\\\", \\\"mô tả cảnh 3\\\", \\\"mô tả cảnh 4\\\"], \\\"overlay_text\\\": [\\\"Text scene 1 (ngắn)\\\", \\\"Text scene 2 (lợi ích)\\\", \\\"Text scene 3 (kêu gọi)\\\"], \\\"durations\\\": [3, 4, 4, 4], \\\"style\\\": \\\"cinematic\\\" }. Lưu ý: background_prompts mô tả nền phía sau, không chứa người, tỷ lệ 9:16.\"\n    }]\n  }]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        128,
        -96
      ],
      "id": "gemini-plan",
      "name": "Gemini Plan"
    }
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const response = $input.first().json;\nconst text = response.candidates[0].content.parts[0].text || \"\";\nconst jsonStart = text.indexOf('{');\nconst jsonEnd = text.lastIndexOf('}');\n\nif (jsonStart === -1 || jsonEnd === -1) {\n  throw new Error(\"Gemini không trả về JSON hợp lệ: \" + text);\n}\n\nconst jsonStr = text.substring(jsonStart, jsonEnd + 1);\nlet data;\ntry {\n  data = JSON.parse(jsonStr);\n} catch (e) {\n  throw new Error(\"JSON Parse Error: \" + e.message);\n}\n\nconst originalInfo = $(\"Read Pending Tasks\").first().json;\n\nreturn {\n  json: {\n    ...data,\n    original_product: originalInfo\n  }\n};",
        "notice": ""
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        -96
      ],
      "id": "parse-gemini-json",
      "name": "Parse Gemini JSON"
    }
    {
      "parameters": {
        "preBuiltAgentsCalloutHttpRequest": "",
        "curlImport": "",
        "method": "POST",
        "url": "={{ $('Set Variables').first().json.CLOUD_RUN_BASE }}/remove-bg",
        "authentication": "none",
        "provideSslCertificates": false,
        "sendQuery": false,
        "sendHeaders": false,
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            {
              "name": "image_url",
              "value": "={{ $json.original_product.image_url }}"
            }
          ]
        },
        "options": {
          "responseFormat": "file"
        },
        "infoMessage": ""
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        736,
        -272
      ],
      "id": "remove-bg",
      "name": "Remove BG"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const binaryData = items[0].binary.data;\nconst base64String = await this.helpers.getBinaryDataBuffer(0, 'data');\n\n// Keep the JSON data from previous node to pass along\nconst jsonData = items[0].json;\n\nreturn [{\n    json: {\n        product_png_base64: base64String.toString('base64'),\n        ...jsonData\n    }\n}];",
        "notice": ""
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        -256
      ],
      "id": "product-to-base64",
      "name": "Product to Base64"
    },
    {
      "parameters": {
        "oldVersionNotice": "",
        "authentication": "googleDriveOAuth2Api",
        "resource": "file",
        "operation": "list",
        "useQueryString": false,
        "limit": 4,
        "queryFilters": {},
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 2,
      "position": [
        1120,
        352
      ],
      "id": "get-backgrounds",
      "name": "Get Backgrounds"
    },
    {
      "parameters": {
        "mode": "mergeByPosition",
        "options": {}
      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [
        1520,
