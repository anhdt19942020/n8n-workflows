              "name": "scenes_base64",
              "value": "={{ $json.scenes_base64 }}"
            },
            {
              "name": "durations",
              "value": "={{ $json.durations }}"
            },
            {
              "name": "overlay_text",
              "value": "={{ $json.overlay_text }}"
            },
            {
              "name": "fps",
              "value": 30
            },
            {
              "name": "size",
              "value": "1080x1920"
            }
          ]
        },
        "options": {
          "timeout": 300000,
          "responseFormat": "file"
        },
        "infoMessage": ""
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2624,
        112
